    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "node-pty": "^1.0.0",
    "session-file-store": "^1.5.0",
    "simple-git": "^3.22.0",
    "ws": "^8.16.0"
  }
