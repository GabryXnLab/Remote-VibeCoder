[Unit]
Description=Claude Mobile Web Server
After=network.target

[Service]
Type=simple
User=%i
WorkingDirectory=/home/%i/claude-mobile/server
ExecStart=/usr/bin/node /home/%i/claude-mobile/server/index.js
Restart=always
RestartSec=5
StartLimitIntervalSec=60
StartLimitBurst=5
Environment=NODE_ENV=production
Environment=PORT=3000
NoNewPrivileges=true
PrivateTmp=true
# NOTE: Do NOT add PrivateDevices=true — node-pty needs /dev/ptmx

[Install]
WantedBy=multi-user.target
