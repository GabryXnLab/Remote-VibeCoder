# Profile: Ampere A1 (1GB RAM + 2GB swap — GCP Ampere A1 o equivalente)
# Tutti i valori usati da setup.sh per generare il service systemd.

PROFILE_NAME="Ampere A1"

# Node.js V8 flags (spazio-separati, inseriti in ExecStart su una riga)
NODE_FLAGS="--max-old-space-size=256 --optimize-for-size --expose-gc --max-semi-space-size=2"

# systemd cgroup memory limits
MEMORY_HIGH="400M"
MEMORY_MAX="512M"

# libuv thread pool (2 è sufficiente per single-user con poca RAM)
UV_THREADPOOL="2"

# Nome della subdirectory sotto $HOME in cui vive l'app
APP_SUBDIR="claude-mobile"
