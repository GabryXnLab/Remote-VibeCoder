# Profile: standard (4GB+ RAM — Oracle Cloud Ampere A1, Hetzner CX22, ecc.)
# Limiti di memoria e flag Node più generosi.

PROFILE_NAME="standard"

# Node.js V8 flags: heap più grande, no ottimizzazione aggressiva per size
NODE_FLAGS="--max-old-space-size=512 --expose-gc"

# systemd cgroup memory limits (lascia ~2.5GB liberi per tmux, Claude Code, git)
MEMORY_HIGH="1024M"
MEMORY_MAX="1536M"

# libuv thread pool standard
UV_THREADPOOL="4"

# Nome della subdirectory sotto $HOME in cui vive l'app
APP_SUBDIR="claude-mobile"
